# 复制到服务器: /etc/silliconthink/application-prod.yml
# 库名 / 账号 / 密码等敏感项请写在 /etc/silliconthink/backend.env（环境变量）
# 不要把真实密码提交到 Git

server:
  port: ${SERVER_PORT:8080}

spring:
  datasource:
    url: jdbc:mysql://${DB_HOST:127.0.0.1}:${DB_PORT:3306}/${DB_NAME}?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
    username: ${DB_USERNAME}
    password: ${DB_PASSWORD}

app:
  jwt:
    secret: ${JWT_SECRET}
    expire-seconds: ${JWT_EXPIRE_SECONDS:7200}
  cors:
    allowed-origins:
      - https://siliconthink.top
      - https://www.siliconthink.top
  oauth:
    frontend-callback-url: ${OAUTH_FRONTEND_CALLBACK:https://siliconthink.top/oauth/callback}
    github:
      client-id: ${GITHUB_CLIENT_ID:}
      client-secret: ${GITHUB_CLIENT_SECRET:}
      redirect-uri: ${GITHUB_REDIRECT_URI:https://siliconthink.top/api/v1/auth/oauth/github/callback}

logging:
  level:
    com.silliconthink: INFO
    root: WARN
