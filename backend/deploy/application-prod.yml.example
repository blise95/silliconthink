# 复制到服务器: /etc/silliconthink/application-prod.yml
# 不要提交真实密码到 Git

server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/silliconthink?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
    username: silliconthink
    password: CHANGE_ME_DB_PASSWORD

app:
  jwt:
    secret: CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS
    expire-seconds: 7200
  cors:
    allowed-origins:
      - https://siliconthink.top
      - https://www.siliconthink.top
  oauth:
    frontend-callback-url: https://siliconthink.top/oauth/callback
    github:
      client-id: YOUR_GITHUB_CLIENT_ID
      client-secret: YOUR_GITHUB_CLIENT_SECRET
      redirect-uri: https://siliconthink.top/api/v1/auth/oauth/github/callback

logging:
  level:
    com.silliconthink: INFO
    root: WARN
