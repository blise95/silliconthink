# 复制到服务器: /etc/silliconthink/backend.env
# chmod 640 /etc/silliconthink/backend.env
# chown root:www-data /etc/silliconthink/backend.env
# 然后: sudo systemctl restart silliconthink-backend
#
# 安全：勿把填好真实密钥的本文件提交到 Git。仓库中只保留本 .example。

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=silliconthink
DB_USERNAME=silliconthink
DB_PASSWORD=换成你的数据库密码

JWT_SECRET=换成至少32位的随机字符串
JWT_EXPIRE_SECONDS=7200

# 日志目录（文件：${LOG_PATH}/backend.log）
LOG_PATH=/var/log/silliconthink

# 博客对象存储根（正文 + 图片）。本机目录或 NAS 挂载均可。
# 香草云本机示例：
BLOG_STORAGE_ROOT=/var/lib/silliconthink/blog-storage
# NAS 示例（需先挂载，见 deploy/nas-storage.md）：
# BLOG_STORAGE_ROOT=/mnt/nas-blog
# 媒体目录默认 ${BLOG_STORAGE_ROOT}/media；一般无需再设
# UPLOAD_DIR=
# 一次性正文迁移（导出 content_md → 对象），用完即关
# BLOG_MIGRATE_CONTENT=false

# 可选
# SERVER_PORT=8080
# OAUTH_FRONTEND_CALLBACK=https://example.com/oauth/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=https://example.com/api/v1/auth/oauth/github/callback
