# Copy to application-local.yml (do not commit real secrets)
# 也可直接在 shell 里 export DB_* / JWT_* 覆盖

spring:
  datasource:
    url: jdbc:mysql://${DB_HOST:127.0.0.1}:${DB_PORT:3306}/${DB_NAME:silliconthink}?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
    username: ${DB_USERNAME:root}
    password: ${DB_PASSWORD:your_mysql_password}

app:
  jwt:
    secret: ${JWT_SECRET:replace-with-a-long-random-secret-at-least-32-chars}
    expire-seconds: 7200
  cors:
    allowed-origins:
      - http://localhost:5173
  oauth:
    frontend-callback-url: http://localhost:5173/oauth/callback
    github:
      client-id: ${GITHUB_CLIENT_ID:}
      client-secret: ${GITHUB_CLIENT_SECRET:}
      redirect-uri: http://localhost:8080/api/v1/auth/oauth/github/callback
  storage:
    root: ${BLOG_STORAGE_ROOT:data/blog-storage}
