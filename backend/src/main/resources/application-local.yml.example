# Copy to application-local.yml (do not commit real secrets)
spring:
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/silliconthink?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
    username: root
    password: your_mysql_password

app:
  jwt:
    secret: replace-with-a-long-random-secret-at-least-32-chars
    expire-seconds: 7200
  cors:
    allowed-origins:
      - http://localhost:5173
  oauth:
    frontend-callback-url: http://localhost:5173/oauth/callback
    github:
      client-id: your_github_oauth_app_client_id
      client-secret: your_github_oauth_app_client_secret
      redirect-uri: http://localhost:8080/api/v1/auth/oauth/github/callback
