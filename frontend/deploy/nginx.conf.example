# Nginx 配置 — siliconthink.top（前端静态 + 后端 API 反代）
# sudo cp nginx.conf.example /etc/nginx/sites-available/silliconthink
# sudo ln -sf /etc/nginx/sites-available/silliconthink /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;
    server_name siliconthink.top www.siliconthink.top;

    root /var/www/silliconthink;
    index index.html;

    # 后端 API（本机 Spring Boot :8080）
    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 博客媒体（方案 A：反代到后端；与 app.upload.public-path-prefix=/uploads 一致）
    location /uploads/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        expires 7d;
        access_log off;
    }

    # 方案 B（可选）：Nginx 直接读 NAS 挂载，需挂载对 nginx 用户可读
    # location /uploads/ {
    #     alias /mnt/nas-blog/media/;
    #     expires 7d;
    #     access_log off;
    # }

    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
    gzip_min_length 256;
}

# HTTPS:
# sudo apt install -y certbot python3-certbot-nginx
# sudo certbot --nginx -d siliconthink.top -d www.siliconthink.top
